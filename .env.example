# Copy to .env and fill only what you need.

# MiniMax Anthropic-compatible API, same shape as the Deep Agents demo.
ANTHROPIC_API_KEY=your-minimax-subscription-key
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic/v1

# Optional overrides.
ZENFORGE_MODEL=auto
ZENFORGE_APPROVE=auto
ZENFORGE_DOCKER=true
ZENFORGE_DOCKER_IMAGE=alpine:3.20
# Leave empty to type at the You: prompt.
ZENFORGE_QUESTION=
